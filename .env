# Environment variables for Race Timer server
# Copy this file to .env (or edit in place) and fill in your Pusher credentials.
# Do NOT commit secrets to a public repository.

# Server port (optional)
PORT=3001

# Pusher credentials (optional). If left empty, Pusher publishing is disabled.
PUSHER_APP_ID="2167134"
PUSHER_KEY="e60902c7c03717fa93cb"
PUSHER_SECRET="600ad5c5ce3f98af2014"
PUSHER_CLUSTER="us2"

# Usage:
# 1) Install dotenv: npm install dotenv
# 2) Either add `require('dotenv').config()` at top of server.js
#    or start the server with: node -r dotenv/config server.js
